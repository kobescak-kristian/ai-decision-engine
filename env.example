# AI Decision Engine — environment variables
# Copy this to .env and fill in your values

# OpenAI (optional — system runs in simulation mode without this)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Pipeline thresholds
CONFIDENCE_THRESHOLD=0.60

# Evaluation thresholds (used by the insights engine)
MIN_CONVERSION_RATE=0.40
MAX_FALSE_POSITIVE_RATE=0.30
MAX_MANUAL_REVIEW_RATE=0.25

# Database
DB_PATH=data/decisions.db
